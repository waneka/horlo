# Anthropic API Key (optional)
# Required for LLM-powered extraction when structured data is incomplete
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Supabase Postgres (required for data layer)
# Use the Transaction pooler connection string from Supabase Dashboard
# Project Settings -> Database -> Connection string -> URI (port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase Auth (required for Phase 4)
# Local dev: `supabase start` prints these values via `supabase status`
# Default local URL is http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi... # from `supabase status`

# Supabase Service Role Key (required for Delete Account — Plan 41-02)
# Used exclusively by the Delete Account server action (auth.admin.deleteUser()).
# This key bypasses Row Level Security — treat as a secret and never expose to the client.
# Server-only: never import this key in any 'use client' component.
# Source: Supabase Dashboard -> Project Settings -> API -> service_role key
#   (labelled "service_role" under legacy "Project API keys", or "Secret key" under newer API key naming)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Read-only prod connection string; required ONLY for scripts/inventory-explore-catalog.ts.
# Use the direct connection (port 5432) or Session pooler from Supabase Dashboard
# → Database → Connection string → URI. NEVER commit this to .env.local — supply via shell env:
#   PROD_DATABASE_URL=postgresql://... npm run explore:inventory
PROD_DATABASE_URL=

# Vercel AI Gateway API key (https://vercel.com/dashboard → AI → Gateway).
# Required ONLY for scripts/generate-explore-covers.ts.
# Default model: openai/gpt-image-1 at medium quality 1536×1024.
# Add to .env.local before running: npm run explore:covers
AI_GATEWAY_API_KEY=
